rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /price_standards/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /partner_locations/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /alert_zones/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
